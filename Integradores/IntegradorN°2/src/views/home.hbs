<div class="container">
    <!-- Hero / banner -->
    <div class="row align-items-center bg-light rounded p-4 mb-4">
        <div class="col-lg-6">
            <h1 class="display-6">Encuentra lo que necesitas</h1>
            <p class="lead">Ofertas, novedades y envíos rápidos. Compra fácil y seguro.</p>
        </div>
        <div class="col-lg-6 text-center">
            <img src="https://i.pinimg.com/736x/12/f8/99/12f899172d8d14c48ace7730ab57c2d6.jpg" alt="Banner" class="img-fluid" style="max-height:300px; object-fit:cover;">
        </div>
    </div>

    <!-- Categorías (estáticas) -->
    <h5 class="mb-3">Categorías</h5>
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <a href="/categories/electronica" class="card card-hover text-decoration-none text-dark h-100">
                <img src="https://acdn-us.mitiendanube.com/stores/006/281/009/themes/toluca/2-slide-1762830480977-914735399-4e12801b1c41e29b20046639c7b6d97a1762830486-480-0.webp?8525521617863635409" class="card-img-top" alt="Electrónica" style="height:120px; object-fit:cover;">
                <div class="card-body py-2">
                    <p class="card-text text-center mb-0">Electrónica</p>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a href="/categories/ropa" class="card card-hover text-decoration-none text-dark h-100">
                <img src="https://acdn-us.mitiendanube.com/stores/006/281/009/themes/toluca/2-slide-1762830480977-4473705324-2f1fc154bc83bb63f435a098d91d372e1762830487-480-0.webp?8525521617863635409" class="card-img-top" alt="Ropa" style="height:120px; object-fit:cover;">
                <div class="card-body py-2">
                    <p class="card-text text-center mb-0">Ropa</p>
                </div>
            </a>
        </div>
        <div class="container">
            {{!-- Hero / banner --}}
            <div class="row align-items-center bg-light rounded p-4 mb-4">
                <div class="col-lg-6">
                    <h1 class="display-6">Encuentra lo que necesitas</h1>
                    <p class="lead">Ofertas, novedades y envíos rápidos. Compra fácil y seguro.</p>
                    <a href="/categories" class="btn btn-primary btn-lg">Ver categorías</a>
                </div>
                <div class="col-lg-6 text-center">
                    <img src="{{heroImageUrl}}" alt="Banner" class="img-fluid" style="max-height:220px; object-fit:cover;">
                </div>
            </div>

            {{!-- Categorías --}}
            {{#if categories}}
                <h5 class="mb-3">Categorías</h5>
                <div class="row g-3 mb-4">
                    {{#each categories}}
                        <div class="col-6 col-md-3">
                            <a href="/categories/{{this.slug}}" class="card text-decoration-none text-dark h-100">
                                <img src="{{this.image}}" class="card-img-top" alt="{{this.name}}" style="height:120px; object-fit:cover;">
                                <div class="card-body py-2">
                                    <p class="card-text text-center mb-0">{{this.name}}</p>
                                </div>
                            </a>
                        </div>
                    {{/each}}
                </div>
            {{/if}}

            {{!-- Productos destacados --}}
            {{#if featured}}
                <h5 class="mb-3">Destacados</h5>
                <div class="row g-3 mb-4">
                    {{#each featured}}
                        <div class="col-6 col-md-3">
                            <div class="card h-100">
                                <a href="/product/{{this.id}}">
                                    <img src="{{this.image}}" class="card-img-top" alt="{{this.title}}" style="height:180px; object-fit:cover;">
                                </a>
                                <div class="card-body d-flex flex-column">
                                    <h6 class="card-title mb-1">{{this.title}}</h6>
                                    <p class="text-muted mb-2 small">{{this.brand}}</p>
                                    <div class="mt-auto d-flex justify-content-between align-items-center">
                                        <div>
                                            <strong class="text-primary">{{formatPrice this.price}}</strong>
                                        </div>
                                        <form action="/cart/add" method="POST" class="m-0">
                                            <input type="hidden" name="productId" value="{{this.id}}">
                                            <button class="btn btn-sm btn-outline-primary" type="submit">Agregar</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    {{/each}}
                </div>
            {{/if}}

            {{!-- Lista general de productos --}}
            <h5 class="mb-3">Productos populares</h5>
            <div class="row g-4">
                {{#each products}}
                    <div class="col-6 col-md-4 col-lg-3">
                        <div class="card h-100">
                            <a href="/product/{{this.id}}">
                                <img src="{{this.image}}" class="card-img-top" alt="{{this.title}}" style="height:160px; object-fit:cover;">
                            </a>
                            <div class="card-body d-flex flex-column">
                                <h6 class="card-title mb-1">{{this.title}}</h6>
                                <p class="text-muted small mb-2">{{this.category}}</p>
                                <div class="mb-2">
                                    {{#if this.rating}}
                                        <small class="text-warning">{{this.rating}} ★</small>
                                    {{/if}}
                                </div>
                                <div class="mt-auto d-flex justify-content-between align-items-center">
                                    <div>
                                        {{#if this.salePrice}}
                                            <div class="small text-muted text-decoration-line-through">{{formatPrice this.price}}</div>
                                            <div class="fw-bold text-danger">{{formatPrice this.salePrice}}</div>
                                        {{else}}
                                            <div class="fw-bold">{{formatPrice this.price}}</div>
                                        {{/if}}
                                    </div>
                                    <div class="btn-group" role="group">
                                        <a href="/product/{{this.id}}" class="btn btn-sm btn-outline-secondary">Ver</a>
                                        <form action="/cart/add" method="POST" class="m-0">
                                            <input type="hidden" name="productId" value="{{this.id}}">
                                            <button class="btn btn-sm btn-primary" type="submit">Añadir</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                {{/each}}
            </div>

            {{!-- Paginación --}}
            {{#if pagination}}
                <nav aria-label="Paginación" class="mt-4">
                    <ul class="pagination justify-content-center">
                        {{#if pagination.hasPrev}}
                            <li class="page-item"><a class="page-link" href="?page={{pagination.prev}}">Anterior</a></li>
                        {{else}}
                            <li class="page-item disabled"><span class="page-link">Anterior</span></li>
                        {{/if}}

                        {{#each pagination.pages}}
                            <li class="page-item {{#if this.active}}active{{/if}}">
                                <a class="page-link" href="?page={{this.number}}">{{this.number}}</a>
                            </li>
                        {{/each}}

                        {{#if pagination.hasNext}}
                            <li class="page-item"><a class="page-link" href="?page={{pagination.next}}">Siguiente</a></li>
                        {{else}}
                            <li class="page-item disabled"><span class="page-link">Siguiente</span></li>
                        {{/if}}
                    </ul>
                </nav>
            {{/if}}
        </div>