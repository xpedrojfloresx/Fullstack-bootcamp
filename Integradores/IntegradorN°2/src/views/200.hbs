<style>
    /* Ajustes menores */
    .error-200 .card { border: none; }
    .error-200 .display-1 { font-weight: 700; }
</style>

<div class="container error-200 vh-100 d-flex align-items-center justify-content-center">
    <div class="row w-100">
        <div class="col-lg-6 col-md-8 mx-auto text-center">
            <div class="card shadow-sm">
                <div class="card-body py-5">
                    <h1 class="display-1 text-success mb-3">200</h1>
                    <h2 class="h4 mb-3">Éxito</h2>
                    <p class="text-muted mb-4">La solicitud se procesó correctamente.</p>

                    {{!-- Mensaje opcional pasado desde el servidor --}}
                    {{#if message}}
                        <p class="small text-break text-secondary mb-3">{{message}}</p>
                    {{/if}}

                    <a href="/" class="btn btn-primary btn-lg">Volver al inicio</a>

                    {{!-- Mostrar stack solo en desarrollo --}}
                    {{#if showStack}}
                        <pre class="mt-4 small text-start bg-light p-3 rounded" style="max-height:220px;overflow:auto;">{{stack}}</pre>
                    {{/if}}
                </div>
            </div>
            <p class="mt-3 text-muted small">Puede volver al inicio haciendo clic en el botón de arriba.</p>
        </div>
    </div>
</div>